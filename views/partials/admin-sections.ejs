<script nonce="<%= nonce %>">
(() => {
  document.querySelectorAll('.js-log-type-btn[data-logtype]').forEach((btn) => {
    btn.addEventListener('click', () => switchLogType(btn.dataset.logtype));
  });
  document.getElementById('btn-clear-logs')?.addEventListener('click', () => clearLogs());
  document.getElementById('security-view-substats')?.addEventListener('click', () => window.switchSecurityView && window.switchSecurityView('substats'));
  document.getElementById('security-view-multinode')?.addEventListener('click', () => window.switchSecurityView && window.switchSecurityView('multiNode'));
  document.getElementById('btn-load-substats')?.addEventListener('click', () => window.loadSubStats && window.loadSubStats(1));
  document.getElementById('btn-load-multinode')?.addEventListener('click', () => window.loadMultiNodeObservations && window.loadMultiNodeObservations(1));

  // 风控配置
  (async function loadGuardConfig() {
    try {
      const res = await fetch('/admin/api/guard-config', { headers: { 'X-CSRF-Token': window._csrf || '' } });
      const d = await res.json();
      if (!d.ok) return;
      const c = d.config;
      const el = id => document.getElementById(id);
      el('guard-mode').value = c.guard_mode || 'off';
      el('guard-token-window').value = Math.round((parseInt(c.guard_token_window_ms) || 60000) / 1000);
      el('guard-token-max-req').value = parseInt(c.guard_token_max_req) || 20;
      el('guard-token-ban').value = Math.round((parseInt(c.guard_token_ban_ms) || 900000) / 1000);
      el('guard-behavior-window').value = Math.round((parseInt(c.guard_behavior_window_ms) || 120000) / 1000);
      el('guard-max-ips').value = parseInt(c.guard_behavior_max_ips) || 6;
      el('guard-max-uas').value = parseInt(c.guard_behavior_max_uas) || 4;
      el('guard-auto-reset-ua-24h-limit').value = parseInt(c.guard_auto_reset_ua_24h_limit) || 0;
      el('guard-ua-allowlist').value = c.guard_ua_allowlist || '';
    } catch (_) {}
  })();
  document.getElementById('btn-save-guard')?.addEventListener('click', async () => {
    const el = id => document.getElementById(id);
    const config = {
      guard_mode: el('guard-mode').value,
      guard_token_window_ms: String((parseInt(el('guard-token-window').value) || 60) * 1000),
      guard_token_max_req: el('guard-token-max-req').value,
      guard_token_ban_ms: String((parseInt(el('guard-token-ban').value) || 900) * 1000),
      guard_behavior_window_ms: String((parseInt(el('guard-behavior-window').value) || 120) * 1000),
      guard_behavior_max_ips: el('guard-max-ips').value,
      guard_behavior_max_uas: el('guard-max-uas').value,
      guard_auto_reset_ua_24h_limit: el('guard-auto-reset-ua-24h-limit').value,
      guard_ua_allowlist: el('guard-ua-allowlist').value,
    };
    const res = await fetch('/admin/api/guard-config', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ config }) });
    const d = await res.json().catch(() => ({}));
    showToast(d.ok ? '✅ 风控配置已保存' : '❌ 保存失败');
  });

  document.getElementById('btn-save-tg')?.addEventListener('click', () => saveTG());
  document.getElementById('btn-test-tg')?.addEventListener('click', () => testTG());
  document.getElementById('btn-save-smtp')?.addEventListener('click', () => saveSmtpConfig());
  document.getElementById('btn-test-smtp')?.addEventListener('click', () => testSmtp());
  document.querySelectorAll('.tg-event[data-key]').forEach((input) => {
    input.addEventListener('change', () => toggleEvent(input));
  });

  document.getElementById('btn-save-announcement')?.addEventListener('click', () => saveAnnouncement());
  document.getElementById('registration-open-toggle')?.addEventListener('change', async (e) => {
    const open = e.target.checked;
    const res = await fetch('/admin/api/registration-open', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ open }) });
    if (res.ok) showToast(open ? '✅ 已开放注册' : '✅ 已关闭注册');
    else { e.target.checked = !open; showToast('❌ 操作失败'); }
  });
  document.getElementById('auto-delete-unbound-toggle')?.addEventListener('change', async (e) => {
    const open = e.target.checked;
    const res = await fetch('/admin/api/auto-delete-unbound-tg', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ open }) });
    if (res.ok) showToast(open ? '✅ 已开启未绑定自动删除' : '✅ 已关闭未绑定自动删除');
    else { e.target.checked = !open; showToast('❌ 操作失败'); }
  });
  document.getElementById('nodeloc-registration-open-toggle')?.addEventListener('change', async (e) => {
    const open = e.target.checked;
    const res = await fetch('/admin/api/nodeloc-registration-open', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ open }) });
    if (res.ok) showToast(open ? '✅ 已开放 NodeLoc 注册' : '✅ 已关闭 NodeLoc 注册');
    else { e.target.checked = !open; showToast('❌ 操作失败'); }
  });
  document.getElementById('nodeloc-login-open-toggle')?.addEventListener('change', async (e) => {
    const open = e.target.checked;
    const res = await fetch('/admin/api/nodeloc-login-open', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ open }) });
    if (res.ok) showToast(open ? '✅ 已启用 NodeLoc 登录' : '✅ 已隐藏 NodeLoc 登录');
    else { e.target.checked = !open; showToast('❌ 操作失败'); }
  });
  document.getElementById('invite-registration-open-toggle')?.addEventListener('change', async (e) => {
    const open = e.target.checked;
    const res = await fetch('/admin/api/invite-registration-open', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ open }) });
    if (res.ok) showToast(open ? '✅ 已开放邀请码注册' : '✅ 已关闭邀请码注册');
    else { e.target.checked = !open; showToast('❌ 操作失败'); }
  });
  document.getElementById('btn-save-email-domains')?.addEventListener('click', async () => {
    const domains = document.getElementById('allowed-email-domains')?.value?.trim() || '';
    const res = await fetch('/admin/api/allowed-email-domains', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ domains }) });
    showToast(res.ok ? '✅ 已保存' : '❌ 保存失败');
  });
  // 用户组重置周期
  const _grpNames = ['普通用户','VIP 🌿','SVIP 👑','SSVIP 💎'];
  async function loadGroupResetConfig() {
    const res = await fetch('/admin/api/group-reset-config', { headers: { 'X-CSRF-Token': window._csrf || '' } });
    const d = await res.json().catch(() => ({}));
    if (!d.ok) return;
    const container = document.getElementById('group-reset-config');
    container.querySelectorAll('.js-grp-row').forEach(e => e.remove());
    d.groups.forEach(g => {
      const frag = document.createDocumentFragment();
      const label = document.createElement('span');
      label.className = 'text-xs text-gray-300 js-grp-row';
      label.textContent = _grpNames[g.level];
      const mkInput = (field, val) => { const el = document.createElement('input'); el.type='number'; el.min='0'; el.max='365'; el.value=val; el.dataset.level=g.level; el.dataset.field=field; el.className='bg-black/30 text-white px-3 py-1.5 rounded-xl border border-white/10 text-sm js-grp-input js-grp-row'; return el; };
      frag.appendChild(label);
      frag.appendChild(mkInput('uuid', g.uuid_days));
      frag.appendChild(mkInput('sub', g.sub_days));
      container.appendChild(frag);
    });
    const portEl = document.getElementById('port-rotate-days');
    if (portEl && d.port_rotate_days !== undefined) portEl.value = d.port_rotate_days;
  }
  loadGroupResetConfig();
  document.getElementById('btn-save-group-reset')?.addEventListener('click', async () => {
    const inputs = document.querySelectorAll('.js-grp-input');
    const groups = [{},{},{},{}];
    inputs.forEach(el => {
      const l = parseInt(el.dataset.level);
      if (el.dataset.field === 'uuid') groups[l].uuid_days = parseInt(el.value) || 0;
      else groups[l].sub_days = parseInt(el.value) || 0;
    });
    const port_rotate_days = parseInt(document.getElementById('port-rotate-days')?.value) || 0;
    const res = await fetch('/admin/api/group-reset-config', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ groups, port_rotate_days }) });
    const d = await res.json().catch(() => ({}));
    showToast(d.ok ? '✅ 已保存' : '❌ 保存失败');
  });

  document.getElementById('btn-save-default-traffic-limit')?.addEventListener('click', () => saveDefaultTrafficLimit());
  document.getElementById('btn-apply-default-traffic-limit')?.addEventListener('click', () => applyDefaultTrafficLimit());
  document.getElementById('btn-save-default-user-group')?.addEventListener('click', () => saveDefaultUserGroup());

  document.getElementById('btn-save-sub-visibility')?.addEventListener('click', async () => {
    const vless = document.getElementById('sub-visible-vless')?.checked;
    const ss = document.getElementById('sub-visible-ss')?.checked;
    const hy2 = document.getElementById('sub-visible-hy2')?.checked;
    const res = await fetch('/admin/api/sub-visibility', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' }, body: JSON.stringify({ vless, ss, hy2 }) });
    showToast(res.ok ? '✅ 订阅可见性已保存' : '❌ 保存失败');
  });

  document.getElementById('btn-load-all-instances')?.addEventListener('click', () => loadAllInstances(true));

  // ─── AWS 区域筛选 ───
  let _awsRegionsData = null;
  async function loadAwsRegions() {
    const container = document.getElementById('aws-regions-list');
    if (!container) return;
    try {
      const res = await fetch('/admin/api/aws/regions', { credentials: 'same-origin' });
      const d = await res.json();
      _awsRegionsData = d;
      renderAwsRegions(d);
    } catch (e) {
      container.innerHTML = '<span class="text-red-400">加载失败</span>';
    }
  }
  function renderAwsRegions(d) {
    const container = document.getElementById('aws-regions-list');
    const enabledSet = new Set(d.enabled);
    // 按分组组织
    const groups = {};
    for (const region of d.all) {
      const meta = d.meta[region] || { group: '其他', name: region };
      if (!groups[meta.group]) groups[meta.group] = [];
      groups[meta.group].push({ region, name: meta.name });
    }
    const groupOrder = ['美洲', '欧洲', '亚太', '中东与非洲', '其他'];
    const sortedGroups = Object.keys(groups).sort((a, b) => groupOrder.indexOf(a) - groupOrder.indexOf(b));
    let html = '';
    for (const g of sortedGroups) {
      html += `<div class="mb-4 last:mb-0">
        <h4 class="text-gray-400 text-xs font-medium mb-2 uppercase tracking-wider">${g}</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">`;
      for (const item of groups[g]) {
        const checked = enabledSet.has(item.region) ? 'checked' : '';
        const meta = d.meta[item.region] || {};
        const lsBadge = meta.lightsail
          ? '<span class="text-[9px] px-1 py-0.5 rounded bg-cyan-500/15 text-cyan-300 border border-cyan-500/20">EC2+LS</span>'
          : '<span class="text-[9px] px-1 py-0.5 rounded bg-gray-500/15 text-gray-500 border border-gray-500/20">仅 EC2</span>';
        html += `<label class="flex items-center justify-between p-2.5 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
          <div class="flex flex-col text-left min-w-0 flex-1">
            <div class="flex items-center gap-1.5 flex-wrap">
              <span class="text-white text-xs truncate">${item.name}</span>
              ${lsBadge}
            </div>
            <span class="text-gray-600 text-[10px] font-mono">${item.region}</span>
          </div>
          <div class="relative shrink-0 ml-2">
            <input type="checkbox" data-region="${item.region}" class="js-aws-region-toggle sr-only peer" ${checked}>
            <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
            <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
          </div>
        </label>`;
      }
      html += '</div></div>';
    }
    container.innerHTML = html;
    container.classList.remove('text-center', 'py-6');
    updateAwsRegionsCount();
  }
  function updateAwsRegionsCount() {
    const all = document.querySelectorAll('.js-aws-region-toggle');
    const checked = document.querySelectorAll('.js-aws-region-toggle:checked');
    const btnSave = document.getElementById('btn-aws-regions-save');
    if (btnSave) btnSave.textContent = `保存 (${checked.length}/${all.length})`;
  }
  document.addEventListener('change', (e) => {
    if (e.target?.classList?.contains('js-aws-region-toggle')) updateAwsRegionsCount();
  });
  document.getElementById('btn-aws-regions-all')?.addEventListener('click', () => {
    document.querySelectorAll('.js-aws-region-toggle').forEach(c => { c.checked = true; });
    updateAwsRegionsCount();
  });
  document.getElementById('btn-aws-regions-none')?.addEventListener('click', () => {
    document.querySelectorAll('.js-aws-region-toggle').forEach(c => { c.checked = false; });
    updateAwsRegionsCount();
  });
  document.getElementById('btn-aws-regions-save')?.addEventListener('click', async () => {
    const regions = Array.from(document.querySelectorAll('.js-aws-region-toggle:checked')).map(c => c.dataset.region);
    const btn = document.getElementById('btn-aws-regions-save');
    btn.disabled = true;
    try {
      const res = await fetch('/admin/api/aws/regions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' },
        body: JSON.stringify({ regions }),
      });
      const d = await res.json();
      if (d.ok) showToast(`✅ 已保存 ${d.count} 个启用区域`);
      else showToast('❌ ' + (d.error || '保存失败'));
    } catch { showToast('❌ 网络错误'); }
    btn.disabled = false;
    updateAwsRegionsCount();
  });
  // 切换到 AWS Tab 时加载（也支持页面初次直接进入 AWS Tab）
  // 监听点击和键盘切换两种入口
  document.querySelectorAll('.tab-btn[data-tab="aws"]').forEach(b => b.addEventListener('click', () => {
    if (!_awsRegionsData) loadAwsRegions();
  }));
  // hash 直接定位到 #aws，或包装 switchTab 钩子
  if (typeof window.switchTab === 'function') {
    const _origSwitch = window.switchTab;
    window.switchTab = function (name) {
      _origSwitch(name);
      if (name === 'aws' && !_awsRegionsData) loadAwsRegions();
    };
  }
  // 进入页面时直接加载（即便不在 aws tab 也无副作用，只是预先填好数据）
  loadAwsRegions();
  document.getElementById('btn-auto-bind-aws')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-auto-bind-aws');
    btn.disabled = true; btn.textContent = '⏳ 匹配中...';
    try {
      const res = await fetch('/admin/api/aws/auto-bind', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window._csrf || '' } });
      const d = await res.json();
      if (d.ok) {
        showToast(d.bound ? `✅ 已自动绑定 ${d.bound} 个节点` : '没有找到可匹配的未绑定节点');
        if (d.bound) loadAllInstances(true);
      } else showToast('❌ ' + (d.error || '绑定失败'));
    } catch { showToast('❌ 网络错误'); }
    btn.disabled = false; btn.textContent = '🔗 智能绑定';
  });
  document.getElementById('btn-test-socks-proxy')?.addEventListener('click', () => testSocksProxy());
  document.getElementById('btn-save-aws-config')?.addEventListener('click', () => saveAwsConfig());

  document.querySelectorAll('.js-swap-node-ip').forEach((btn) => {
    btn.addEventListener('click', () => swapNodeIp(Number(btn.dataset.nodeId || 0), btn.dataset.nodeName || ''));
  });
  document.querySelectorAll('.js-unbind-aws').forEach((btn) => {
    btn.addEventListener('click', () => unbindAws(Number(btn.dataset.nodeId || 0)));
  });
  document.querySelectorAll('.js-show-bind-aws').forEach((btn) => {
    btn.addEventListener('click', () => showBindAws(Number(btn.dataset.nodeId || 0)));
  });

  const awsEditModal = document.getElementById('aws-edit-modal');
  if (awsEditModal) {
    awsEditModal.addEventListener('click', (e) => {
      if (e.target === awsEditModal) closeAwsEditModal();
    });
  }
  document.getElementById('btn-test-edit-socks-proxy')?.addEventListener('click', () => testSocksProxyInput('edit-aws-socks', 'edit-aws-socks-test'));
  document.getElementById('btn-save-aws-edit')?.addEventListener('click', () => saveAwsEdit());
  document.getElementById('btn-close-aws-edit-modal')?.addEventListener('click', () => closeAwsEditModal());

  document.getElementById('btn-confirm-bind-aws')?.addEventListener('click', () => confirmBindAws());
  document.getElementById('btn-cancel-bind-aws')?.addEventListener('click', () => {
    document.getElementById('aws-bind-modal')?.classList.add('hidden');
  });

  // ─── 自动化运维配置 ───
  function updateFreezeOptionsVisibility() {
    const trafficEnabled = document.getElementById('auto-freeze-traffic-enabled')?.checked;
    const trafficOpts = document.getElementById('traffic-freeze-options');
    if (trafficOpts) trafficOpts.style.opacity = trafficEnabled ? '1' : '0.4';

    const noCheckinEnabled = document.getElementById('auto-freeze-no-checkin-enabled')?.checked;
    const noCheckinOpts = document.getElementById('no-checkin-freeze-options');
    if (noCheckinOpts) noCheckinOpts.style.opacity = noCheckinEnabled ? '1' : '0.4';

    const alertEnabled = document.getElementById('traffic-alert-enabled')?.checked;
    const alertOpts = document.getElementById('traffic-alert-options');
    if (alertOpts) alertOpts.style.opacity = alertEnabled ? '1' : '0.4';
  }

  document.getElementById('auto-freeze-traffic-enabled')?.addEventListener('change', updateFreezeOptionsVisibility);
  document.getElementById('auto-freeze-no-checkin-enabled')?.addEventListener('change', updateFreezeOptionsVisibility);
  document.getElementById('traffic-alert-enabled')?.addEventListener('change', updateFreezeOptionsVisibility);

  async function loadAutomationConfig() {
    try {
      const res = await fetch('/admin/api/automation-config', { credentials: 'same-origin' });
      const cfg = await res.json();

      // 流量超标开关
      const trafficToggle = document.getElementById('auto-freeze-traffic-enabled');
      if (trafficToggle) trafficToggle.checked = cfg.auto_freeze_traffic_enabled === 'true';

      // 流量策略
      const actionSel = document.getElementById('traffic-exceed-action');
      if (actionSel && cfg.traffic_exceed_action) actionSel.value = cfg.traffic_exceed_action;
      const threshEl = document.getElementById('traffic-exceed-threshold-gb');
      if (threshEl && cfg.traffic_exceed_threshold_gb) threshEl.value = cfg.traffic_exceed_threshold_gb;
      const hardEl = document.getElementById('traffic-exceed-hard-limit-gb');
      if (hardEl && cfg.traffic_exceed_hard_limit_gb) hardEl.value = cfg.traffic_exceed_hard_limit_gb;

      // 未签到冻结开关 + 天数
      const noCheckinToggle = document.getElementById('auto-freeze-no-checkin-enabled');
      if (noCheckinToggle) noCheckinToggle.checked = cfg.auto_freeze_no_checkin_enabled === 'true';
      const daysEl = document.getElementById('auto-freeze-no-checkin-days');
      if (daysEl && cfg.auto_freeze_no_checkin_days) daysEl.value = cfg.auto_freeze_no_checkin_days;

      // 用户流量预警
      const alertToggle = document.getElementById('traffic-alert-enabled');
      if (alertToggle) alertToggle.checked = cfg.traffic_alert_enabled === 'true';
      const alertGbEl = document.getElementById('traffic-alert-threshold-gb');
      if (alertGbEl && cfg.traffic_alert_threshold_gb) alertGbEl.value = cfg.traffic_alert_threshold_gb;

      updateFreezeOptionsVisibility();
    } catch (e) { console.error('加载自动化配置失败', e); }
  }

  document.getElementById('btn-save-automation')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-save-automation');
    const restore = typeof btnLoading === 'function' ? btnLoading(btn, '保存中...') : null;
    try {
      const body = {
        traffic_exceed_action: document.getElementById('traffic-exceed-action')?.value || 'notify',
        traffic_exceed_threshold_gb: document.getElementById('traffic-exceed-threshold-gb')?.value || '20',
        traffic_exceed_hard_limit_gb: document.getElementById('traffic-exceed-hard-limit-gb')?.value || '50',
        auto_freeze_traffic_enabled: document.getElementById('auto-freeze-traffic-enabled')?.checked ? 'true' : 'false',
        auto_freeze_no_checkin_enabled: document.getElementById('auto-freeze-no-checkin-enabled')?.checked ? 'true' : 'false',
        auto_freeze_no_checkin_days: document.getElementById('auto-freeze-no-checkin-days')?.value || '30',
        traffic_alert_enabled: document.getElementById('traffic-alert-enabled')?.checked ? 'true' : 'false',
        traffic_alert_threshold_gb: document.getElementById('traffic-alert-threshold-gb')?.value || '100',
      };
      const res = await fetch('/admin/api/automation-config', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': window._csrf || '' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (data.ok) toast('自动化配置已保存', 2000);
      else toast('保存失败: ' + (data.error || ''), 3000, 'error');
    } catch (e) { toast('保存失败: ' + e.message, 3000, 'error'); }
    finally { if (restore) restore(); }
  });

  document.getElementById('btn-agent-update-all')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-agent-update-all');
    const resultDiv = document.getElementById('agent-update-result');
    const ok = await _confirm('确认要批量更新所有在线 Agent 吗？\n\nAgent 将下载最新代码并自动重启。');
    if (!ok) return;
    const restore = typeof btnLoading === 'function' ? btnLoading(btn, '更新中...') : null;
    try {
      const res = await fetch('/admin/api/agents/update-all', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': window._csrf || '' },
      });
      const data = await res.json();
      if (resultDiv) {
        resultDiv.classList.remove('hidden');
        if (data.total === 0) {
          resultDiv.textContent = '当前没有在线 Agent';
        } else {
          resultDiv.innerHTML = '';
          const header = document.createElement('div');
          header.className = 'mb-1 text-gray-300';
          header.textContent = `更新完成: ${data.successCount || 0}/${data.total} 成功`;
          resultDiv.appendChild(header);
          for (const r of (data.results || [])) {
            const span = document.createElement('span');
            span.className = r.success ? 'text-emerald-400' : 'text-red-400';
            span.textContent = `${r.success ? '✅' : '❌'} ${r.nodeName || r.nodeId}${r.error ? ': ' + r.error : ''}`;
            resultDiv.appendChild(span);
            resultDiv.appendChild(document.createElement('br'));
          }
        }
      }
      toast(`Agent 更新: ${data.successCount || 0}/${data.total || 0} 成功`, 3000);
    } catch (e) { toast('更新失败: ' + e.message, 3000, 'error'); }
    finally { if (restore) restore(); }
  });

  // 暴露给 core.js tab 切换时调用
  window.loadAutomationConfig = loadAutomationConfig;
})();
</script>

<!-- 用户详情弹窗 -->
<div id="user-detail-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60" style="backdrop-filter:blur(4px)">
  <div class="glass rounded-2xl mx-4 overflow-hidden" style="width:100%;max-width:640px">
    <div class="flex items-center justify-between p-4 border-b border-white/5">
      <h3 class="text-white text-sm font-medium" id="ud-title">👤 用户详情</h3>
      <button id="ud-close" class="text-gray-500 hover:text-white text-sm">✕</button>
    </div>
    <div class="overflow-y-auto max-h-[480px] p-4" id="ud-body">
      <p class="text-gray-500 text-sm text-center py-6">加载中...</p>
    </div>
  </div>
</div>
<script nonce="<%= nonce %>">
(function(){
  const modal = document.getElementById('user-detail-modal');
  const body = document.getElementById('ud-body');
  const title = document.getElementById('ud-title');
  document.getElementById('ud-close').onclick = () => modal.classList.add('hidden');
  modal.onclick = e => { if (e.target === modal) modal.classList.add('hidden'); };

  function fmtB(b) {
    if (!b || b <= 0) return '0';
    if (b >= 1073741824) return (b/1073741824).toFixed(2)+' GB';
    if (b >= 1048576) return (b/1048576).toFixed(1)+' MB';
    return (b/1024).toFixed(0)+' KB';
  }

  function esc(v) {
    if (v == null) return '';
    return String(v)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  document.addEventListener('click', async e => {
    const el = e.target.closest('.js-user-detail');
    if (!el) return;
    const uid = el.dataset.userId;
    modal.classList.remove('hidden');
    body.innerHTML = '<p class="text-gray-500 text-sm text-center py-8">加载中...</p>';
    title.textContent = '用户详情';

    try {
      const r = await fetch('/admin/api/users/' + uid + '/detail');
      const d = await r.json();
      if (d.error) { body.innerHTML = '<p class="text-red-400 text-sm text-center">' + d.error + '</p>'; return; }

      const i = d.info;
      title.textContent = i.username;

      // 流量来源分析
      let trafficSrc = '';
      if (d.dailyTraffic && d.dailyTraffic.length) {
        trafficSrc = d.dailyTraffic.map(t =>
          '<div class="flex justify-between text-xs"><span class="text-gray-500">' + t.date + '</span><span class="text-gray-300">↑' + fmtB(t.up) + ' ↓' + fmtB(t.down) + '</span></div>'
        ).join('');
      } else {
        trafficSrc = '<p class="text-gray-600 text-xs">暂无流量记录</p>';
      }

      // 订阅拉取
      let subInfo = '';
      if (d.subAccess && d.subAccess.ips && d.subAccess.ips.length) {
        subInfo = d.subAccess.ips.slice(0, 10).map(s =>
          '<div class="flex justify-between text-xs"><span class="text-gray-500">' + s.ip + ' <span class="text-gray-600">×' + s.count + '</span></span><span class="text-gray-600">' + (s.last_access_display||'') + '</span></div>'
        ).join('');
      } else {
        subInfo = '<p class="text-gray-600 text-xs">24h 内无拉取记录</p>';
      }

      // UA
      let uaInfo = '';
      if (d.subAccess && d.subAccess.uas && d.subAccess.uas.length) {
        uaInfo = d.subAccess.uas.slice(0, 5).map(u =>
          '<div class="text-xs text-gray-500 truncate">' + (u.ua||'').slice(0,60) + ' <span class="text-gray-600">×' + u.count + '</span></div>'
        ).join('');
      }

      // 风险事件
      let riskInfo = '';
      if (d.risk && d.risk.multiNodeEvents && d.risk.multiNodeEvents.length) {
        riskInfo = '<div class="mt-1 space-y-1">' + d.risk.multiNodeEvents.slice(0, 5).map(r =>
          '<div class="text-xs text-orange-300">' + (r.time_display||'') + ' <span class="text-gray-300">' + (r.detail||'').slice(0,80) + '</span></div>'
        ).join('') + '</div>';
      } else {
        riskInfo = '<p class="text-gray-400 text-xs">无异常</p>';
      }

      // 流量来源
      const ts = d.trafficSources || {};
      const other = Math.max(0, (i.traffic_limit||0) - (ts.default||0) - (ts.checkin||0) - (ts.lucky||0));
      const srcItems = [
        {label:'📦 注册赠送', val: ts.default||0},
        {label:'📌 签到', val: ts.checkin||0},
        {label:'🎰 抽奖', val: ts.lucky||0},
        {label:'🎮 其他(猜拳等)', val: other},
      ].filter(s => s.val > 0);
      const srcHtml = srcItems.length ? srcItems.map(s =>
        '<div class="flex justify-between text-xs"><span class="text-gray-400">' + s.label + '</span><span class="text-gray-300">' + fmtB(s.val) + '</span></div>'
      ).join('') : '<p class="text-gray-400 text-xs">无记录</p>';

      const status = i.is_frozen ? '❄️ 冻结' : i.is_blocked ? '🚫 封禁' : '✅ 正常';
      const invitedBy = i.invited_by
        ? `${esc(i.invited_by.inviter_username || '-')}${i.invited_by.inviter_email ? ' <span class="text-gray-500">(' + esc(i.invited_by.inviter_email) + ')</span>' : ''} <span class="text-gray-600">· 码 ' + esc(i.invited_by.code || '-') + '</span>`
        : '<span class="text-gray-500">-</span>';

      body.innerHTML = `
        <table class="w-full text-xs text-left">
          <tbody class="text-gray-300">
            <tr class="border-b border-white/5"><td class="py-2 text-gray-500 w-20">ID</td><td class="py-2">${i.id}</td><td class="py-2 text-gray-500 w-20">状态</td><td class="py-2">${status}</td></tr>
            <tr class="border-b border-white/5"><td class="py-2 text-gray-500">注册</td><td class="py-2 text-gray-400">${i.created_at_display||'-'}</td><td class="py-2 text-gray-500">活跃</td><td class="py-2 text-gray-400">${i.last_login_display||'-'}</td></tr>
            <tr class="border-b border-white/5"><td class="py-2 text-gray-500">邀请人</td><td class="py-2 text-gray-300" colspan="3">${invitedBy}</td></tr>
            <tr class="border-b border-white/5"><td class="py-2 text-gray-500">今日流量</td><td class="py-2">↑${fmtB(d.todayTraffic?.up)} ↓${fmtB(d.todayTraffic?.down)}</td><td class="py-2 text-gray-500">累计流量</td><td class="py-2">↑${fmtB(d.totalTraffic?.up)} ↓${fmtB(d.totalTraffic?.down)}</td></tr>
            <tr class="border-b border-white/5"><td class="py-2 text-gray-500">限额</td><td class="py-2">${i.traffic_limit < 0 ? '∞' : fmtB(i.traffic_limit)}</td><td class="py-2 text-gray-500">到期</td><td class="py-2 text-gray-400">${i.expires_at_display||'永不过期'}</td></tr>
          </tbody>
        </table>
        <div class="mt-3 space-y-2">
          <details class="glass rounded-xl"><summary class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-white">📊 7天流量趋势</summary><div class="px-3 pb-2 space-y-0.5">${trafficSrc}</div></details>
          <details class="glass rounded-xl" open><summary class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-white">💰 流量来源</summary><div class="px-3 pb-2 space-y-0.5">${srcHtml}</div></details>
          <details class="glass rounded-xl"><summary class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-white">📡 订阅拉取 IP（24h）</summary><div class="px-3 pb-2 space-y-0.5">${subInfo}</div></details>
          ${uaInfo ? '<details class="glass rounded-xl"><summary class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-white">📱 客户端 UA</summary><div class="px-3 pb-2 space-y-0.5">' + uaInfo + '</div></details>' : ''}
          <details class="glass rounded-xl"><summary class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-white">⚠️ 风险事件</summary><div class="px-3 pb-2">${riskInfo}</div></details>
        </div>
      `;
    } catch(e) {
      body.innerHTML = '<p class="text-red-400 text-sm text-center">加载失败</p>';
    }
  });
})();
</script>
