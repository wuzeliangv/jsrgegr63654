<!-- 用户管理 Tab -->
<script nonce="<%= nonce %>">
  // 用 \u003c 转义所有 < 字符，防止 USER_GROUPS 内容意外引入脚本结束符
  const _UG = <%- JSON.stringify(USER_GROUPS).replace(/</g, '\\u003c') %>;
  function _groupHtml(lv) {
    const g = _UG[Math.min(Math.max(lv||0,0), _UG.length-1)];
    return `<span style="background:#b8860b;color:#fff;padding:1px 7px;border-radius:6px;font-size:11px">${g.badge ? g.badge+' ' : ''}${g.name}</span>`;
  }
</script>
<div class="tab-panel" data-tab="users">
  <!-- 用户总数 + 搜索 -->
  <div class="flex items-center justify-between mb-3">
    <span class="text-gray-500 text-xs">共 <span class="text-white font-medium" id="users-total-count">-</span> 个用户</span>
    <input type="text" id="user-search" placeholder="搜索用户名..." class="bg-black/30 text-white px-3 py-1.5 rounded-xl border border-white/10 text-xs w-40">
  </div>

  <!-- 移动端卡片容器 -->
  <div class="sm:hidden space-y-3" id="users-cards">
    <div class="text-center text-gray-500 text-sm py-8">加载中...</div>
  </div>
  <!-- 桌面端表格 -->
  <div class="hidden sm:block glass rounded-2xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-gray-500 border-b border-white/5 text-xs">
          <tr>
            <th class="py-3 px-4">用户</th>
            <th class="py-3 px-4 cursor-pointer hover:text-rose-400 transition select-none js-user-sort" data-sort-col="id">ID <span id="sort-icon-id" class="text-xs"></span></th>
            <th class="py-3 px-4 cursor-pointer hover:text-rose-400 transition select-none js-user-sort" data-sort-col="trust_level">用户组 <span id="sort-icon-trust_level" class="text-xs"></span></th>
            <th class="py-3 px-4 cursor-pointer hover:text-rose-400 transition select-none js-user-sort" data-sort-col="total_traffic">已用/限额 <span id="sort-icon-total_traffic" class="text-xs">▼</span></th>
            <th class="py-3 px-4 cursor-pointer hover:text-rose-400 transition select-none js-user-sort" data-sort-col="expires_at">到期 <span id="sort-icon-expires_at" class="text-xs"></span></th>
            <th class="py-3 px-4 cursor-pointer hover:text-rose-400 transition select-none js-user-sort" data-sort-col="last_login">最后活跃 <span id="sort-icon-last_login" class="text-xs"></span></th>
            <th class="py-3 px-4">状态</th>
            <th class="py-3 px-4">操作</th>
          </tr>
        </thead>
        <tbody class="text-gray-300" id="users-tbody">
          <tr><td colspan="8" class="py-8 text-center text-gray-500">加载中...</td></tr>
        </tbody>
      </table>
    </div>
    <!-- 分页 -->
    <div class="flex items-center justify-between px-4 py-3 border-t border-white/5">
      <span class="text-gray-500 text-xs" id="users-page-info"></span>
      <div class="flex gap-1" id="users-pagination"></div>
    </div>
  </div>
  <!-- 移动端分页 -->
  <div class="sm:hidden flex items-center justify-between mt-3">
    <span class="text-gray-500 text-xs" id="users-page-info-m"></span>
    <div class="flex gap-1" id="users-pagination-m"></div>
  </div>

  <script nonce="<%= nonce %>">
  (function(){
    const csrfToken = '<%= csrfToken %>';
    window._csrf = csrfToken;
    let _searchTimer = null;
    let _userSortBy = 'total_traffic';
    let _userSortDir = 'DESC';
    let _currentPage = 1;
    const _userNameById = new Map();
    const _userExpiryById = new Map();

    function _escHtml(v) {
      if (v == null) return '';
      return String(v)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function _safeAvatarUrl(url) {
      if (!url) return '';
      const raw = String(url).trim();
      if (!raw) return '';
      if (/^https?:\/\//i.test(raw) || raw.startsWith('/')) return _escHtml(raw);
      return '';
    }

    window.setTrafficLimitById = function(userId, currentLimit) {
      const username = _userNameById.get(userId) || String(userId);
      setTrafficLimit(userId, username, currentLimit);
    };
    window.setExpiryById = function(userId) {
      const username = _userNameById.get(userId) || String(userId);
      const currentExpiry = _userExpiryById.get(userId) || '';
      setExpiry(userId, username, currentExpiry);
    };

    window.sortUsers = function(col) {
      if (_userSortBy === col) {
        _userSortDir = _userSortDir === 'DESC' ? 'ASC' : 'DESC';
      } else {
        _userSortBy = col;
        _userSortDir = 'DESC';
      }
      // 更新图标
      document.querySelectorAll('[id^="sort-icon-"]').forEach(el => el.textContent = '');
      const icon = document.getElementById('sort-icon-' + col);
      if (icon) icon.textContent = _userSortDir === 'DESC' ? '▼' : '▲';
      loadUsers(1);
    }

    function _fmtBytes(b) {
      if (!b || b === 0) return '0 B';
      const u = ['B','KB','MB','GB','TB'];
      const i = Math.min(Math.floor(Math.log(b) / Math.log(1024)), u.length - 1);
      return (b / Math.pow(1024, i)).toFixed(i > 0 ? 2 : 0) + ' ' + u[i];
    }

    window.loadUsers = async function(page = 1) {
      _currentPage = page;
      const search = (document.getElementById('user-search').value || '').trim();
      const params = new URLSearchParams({ page, search, sortBy: _userSortBy, sortDir: _userSortDir });
      const resp = await fetch('/admin/api/users?' + params);
      const data = await resp.json();
      const tbody = document.getElementById('users-tbody');
      const cards = document.getElementById('users-cards');
      const total = data.total;
      document.getElementById('users-total-count').textContent = total;

      if (!data.rows || data.rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="py-8 text-center text-gray-500">无匹配用户</td></tr>';
        cards.innerHTML = '<div class="text-center text-gray-500 text-sm py-8">无匹配用户</div>';
        document.getElementById('users-page-info').textContent = '';
        document.getElementById('users-pagination').innerHTML = '';
        document.getElementById('users-page-info-m').textContent = '';
        document.getElementById('users-pagination-m').innerHTML = '';
        return;
      }

      // 公共数据
      _userNameById.clear();
      _userExpiryById.clear();
      const rowsHtml = data.rows.map(u => {
        _userNameById.set(u.id, String(u.username || ''));
        _userExpiryById.set(u.id, String(u.expires_at || ''));
        const safeUsername = _escHtml(u.username || '');
        const safeAvatar = _safeAvatarUrl(u.avatar_url);
        const safeLastLogin = _escHtml(u.last_login || '-');
        const safeUserId = Number(u.id) || 0;
        const statusClass = u.is_blocked ? 'bg-red-500/20 text-red-300' : u.is_frozen ? 'bg-blue-500/20 text-blue-300' : 'bg-emerald-500/20 text-emerald-300';
        const statusText = u.is_blocked ? '已封禁' : u.is_frozen ? '已冻结' : '正常';
        const blockBtnClass = u.is_blocked ? 'text-emerald-400' : 'text-red-400';
        const blockBtnText = u.is_blocked ? '解封' : '封禁';
        const limitText = u.traffic_limit < 0 ? '∞' : _fmtBytes(u.traffic_limit);
        const expiryText = u.expires_at ? u.expires_at.slice(0,10) : '永久';
        const expiryClass = u.expires_at && new Date(u.expires_at) < new Date() ? 'text-red-400' : 'text-gray-400';
        return { u, safeUsername, safeAvatar, safeLastLogin, safeUserId, statusClass, statusText, blockBtnClass, blockBtnText, limitText, expiryText, expiryClass };
      });

      // 桌面端表格
      tbody.innerHTML = rowsHtml.map(({u, safeUsername, safeAvatar, safeLastLogin, safeUserId, statusClass, statusText, blockBtnClass, blockBtnText, limitText, expiryText, expiryClass}) => {
        return `<tr class="border-b border-white/5 hover:bg-white/[0.02]">
          <td class="py-3 px-4 flex items-center gap-2">
            <img src="${safeAvatar}" class="w-6 h-6 rounded-full ring-1 ring-white/10 bg-gray-800 js-avatar-fallback">
            <span class="text-white text-sm cursor-pointer hover:text-cyan-400 hover:underline js-user-detail" data-user-id="${safeUserId}">${safeUsername}</span>
            ${u.is_admin ? '<span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-500/20 text-amber-300">管理</span>' : ''}
          </td>
          <td class="py-3 px-4 text-xs text-gray-500">${safeUserId}</td>
          <td class="py-3 px-4 text-xs"><span class="cursor-pointer hover:underline js-set-group" data-user-id="${safeUserId}" data-current-level="${u.trust_level||0}">${_groupHtml(u.trust_level)}</span></td>
          <td class="py-3 px-4 text-xs text-gray-400">
            ${_fmtBytes(u.total_traffic || 0)} / <span class="cursor-pointer text-cyan-400 hover:underline js-set-traffic-limit" data-user-id="${safeUserId}" data-current-limit="${u.traffic_limit || 0}">${limitText}</span>
          </td>
          <td class="py-3 px-4 text-xs"><span class="cursor-pointer ${expiryClass} hover:underline js-set-expiry" data-user-id="${safeUserId}">${expiryText}</span></td>
          <td class="py-3 px-4 text-xs text-gray-500">${safeLastLogin}</td>
          <td class="py-3 px-4"><span class="text-[10px] px-2 py-0.5 rounded-full ${statusClass}">${statusText}</span></td>
          <td class="py-3 px-4 space-x-2">
            <form method="POST" action="/admin/api/users/${safeUserId}/toggle-block" class="inline"><input type="hidden" name="_csrf" value="${csrfToken}"><button class="text-xs ${blockBtnClass} hover:underline">${blockBtnText}</button></form>
            <form method="POST" action="/admin/api/users/${safeUserId}/reset-token" class="inline"><input type="hidden" name="_csrf" value="${csrfToken}"><button type="button" class="text-xs text-amber-400 hover:underline js-reset-token-btn">重置</button></form>
            ${u.is_admin ? '' : `<button class="text-xs text-gray-500 hover:text-red-400 hover:underline js-delete-user" data-user-id="${safeUserId}" data-username="${safeUsername}">删除</button>`}
          </td>
        </tr>`;
      }).join('');

      // 移动端卡片
      cards.innerHTML = rowsHtml.map(({u, safeUsername, safeAvatar, safeLastLogin, safeUserId, statusClass, statusText, blockBtnClass, blockBtnText, limitText, expiryText, expiryClass}) => {
        return `<div class="glass rounded-2xl p-4 space-y-2">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <img src="${safeAvatar}" class="w-6 h-6 rounded-full ring-1 ring-white/10 bg-gray-800 js-avatar-fallback">
              <span class="text-white text-sm font-medium cursor-pointer hover:text-cyan-400 js-user-detail" data-user-id="${safeUserId}">${safeUsername}</span>
              ${u.is_admin ? '<span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-500/20 text-amber-300">管理</span>' : ''}
            </div>
            <span class="text-[10px] px-2 py-0.5 rounded-full ${statusClass}">${statusText}</span>
          </div>
          <div class="grid grid-cols-2 gap-1.5 text-xs">
            <div><span class="text-gray-500">ID</span><span class="block text-gray-400 mt-0.5">${safeUserId}</span></div>
            <div><span class="text-gray-500">用户组</span><span class="block mt-0.5 cursor-pointer js-set-group" data-user-id="${safeUserId}" data-current-level="${u.trust_level||0}">${_groupHtml(u.trust_level)}</span></div>
            <div><span class="text-gray-500">流量</span><span class="block text-gray-400 mt-0.5">${_fmtBytes(u.total_traffic || 0)} / <span class="cursor-pointer text-cyan-400 js-set-traffic-limit" data-user-id="${safeUserId}" data-current-limit="${u.traffic_limit || 0}">${limitText}</span></span></div>
            <div><span class="text-gray-500">到期</span><span class="block mt-0.5 cursor-pointer ${expiryClass} js-set-expiry" data-user-id="${safeUserId}">${expiryText}</span></div>
            <div class="col-span-2"><span class="text-gray-500">最后活跃</span><span class="text-gray-500 ml-2">${safeLastLogin}</span></div>
          </div>
          <div class="flex gap-3 pt-1.5 border-t border-white/5">
            <form method="POST" action="/admin/api/users/${safeUserId}/toggle-block" class="inline"><input type="hidden" name="_csrf" value="${csrfToken}"><button class="text-xs ${blockBtnClass} hover:underline">${blockBtnText}</button></form>
            <form method="POST" action="/admin/api/users/${safeUserId}/reset-token" class="inline"><input type="hidden" name="_csrf" value="${csrfToken}"><button type="button" class="text-xs text-amber-400 hover:underline js-reset-token-btn">重置</button></form>
            ${u.is_admin ? '' : `<button class="text-xs text-gray-500 hover:text-red-400 hover:underline js-delete-user" data-user-id="${safeUserId}" data-username="${safeUsername}">删除</button>`}
          </div>
        </div>`;
      }).join('');

      // 分页信息
      const limit = 20;
      const pages = Math.ceil(total / limit);
      const start = (page - 1) * limit + 1;
      const end = Math.min(page * limit, total);
      document.getElementById('users-page-info').textContent = `第 ${start}-${end} 条，共 ${total} 条`;
      document.getElementById('users-page-info-m').textContent = `${start}-${end} / ${total}`;

      // 分页按钮
      const nav = document.getElementById('users-pagination');
      const navM = document.getElementById('users-pagination-m');
      nav.innerHTML = '';
      navM.innerHTML = '';
      if (pages <= 1) return;
      const mkBtn = (text, p, active) => {
        const b = document.createElement('button');
        b.textContent = text;
        b.className = active ? 'px-2.5 py-1 rounded-lg text-xs bg-rose-600 text-white' : 'px-2.5 py-1 rounded-lg text-xs glass text-gray-400 hover:text-white hover:bg-white/10 transition';
        if (!active) b.onclick = () => loadUsers(p);
        return b;
      };
      if (page > 1) { nav.appendChild(mkBtn('‹', page - 1, false)); navM.appendChild(mkBtn('‹', page - 1, false)); }
      let s = Math.max(1, page - 3), e = Math.min(pages, s + 6);
      if (e - s < 6) s = Math.max(1, e - 6);
      for (let p = s; p <= e; p++) { nav.appendChild(mkBtn(p, p, p === page)); navM.appendChild(mkBtn(p, p, p === page)); }
      if (page < pages) { nav.appendChild(mkBtn('›', page + 1, false)); navM.appendChild(mkBtn('›', page + 1, false)); }
    };

    window.filterUsers = function() {
      clearTimeout(_searchTimer);
      _searchTimer = setTimeout(() => loadUsers(1), 300);
    };

    document.getElementById('user-search').addEventListener('input', filterUsers);
    document.querySelectorAll('.js-user-sort[data-sort-col]').forEach((el) => {
      el.addEventListener('click', () => window.sortUsers(el.dataset.sortCol));
    });
    document.addEventListener('error', (e) => {
      const target = e.target;
      if (target && target.classList && target.classList.contains('js-avatar-fallback')) {
        target.style.display = 'none';
      }
    }, true);
    document.addEventListener('click', (e) => {
      const resetBtn = e.target.closest('.js-reset-token-btn');
      if (resetBtn) {
        _confirm('重置订阅？').then((ok) => {
          if (ok) resetBtn.closest('form')?.submit();
        });
        return;
      }
      const trafficBtn = e.target.closest('.js-set-traffic-limit');
      if (trafficBtn) {
        const userId = Number(trafficBtn.dataset.userId || 0);
        const currentLimit = Number(trafficBtn.dataset.currentLimit || 0);
        if (userId > 0) window.setTrafficLimitById(userId, currentLimit);
        return;
      }
      const expiryBtn = e.target.closest('.js-set-expiry');
      if (expiryBtn) {
        const userId = Number(expiryBtn.dataset.userId || 0);
        if (userId > 0) window.setExpiryById(userId);
        return;
      }
      const groupBtn = e.target.closest('.js-set-group');
      if (groupBtn) {
        const userId = Number(groupBtn.dataset.userId || 0);
        const current = Number(groupBtn.dataset.currentLevel || 0);
        if (userId <= 0) return;
        const opts = _UG.map((g,i) => `${i === current ? '✓ ' : '  '}${i}: ${g.name}${g.badge ? ' '+g.badge : ''}`).join('\n');
        _prompt('设置用户组\n' + opts, String(current)).then(val => {
          if (val === null) return;
          const level = parseInt(val);
          if (isNaN(level) || level < 0 || level > 3) return;
          fetch('/admin/api/users/' + userId + '/set-group', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
            body: JSON.stringify({ level })
          }).then(r => r.json()).then(d => { if (d.ok) loadUsers(_currentPage); });
        });
      }
      const delBtn = e.target.closest('.js-delete-user');
      if (delBtn) {
        const userId = Number(delBtn.dataset.userId || 0);
        const username = delBtn.dataset.username || '';
        if (userId <= 0) return;
        _confirm(`确定删除用户 ${username}？此操作不可恢复`).then(ok => {
          if (!ok) return;
          fetch('/admin/api/users/' + userId + '/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
            body: '{}'
          }).then(r => r.json()).then(d => { if (d.ok) loadUsers(_currentPage); else alert(d.error || '删除失败'); });
        });
      }
    });

    // 初始加载
    loadUsers(1);
  })();
  </script>
</div>

<div class="tab-panel" data-tab="logs">
  <!-- 子 Tab 切换 -->
  <div class="flex gap-2 mb-4">
    <button class="text-xs px-3 py-1.5 rounded-lg transition bg-rose-600 text-white js-log-type-btn" data-logtype="system">🖥️ 系统日志</button>
    <button class="text-xs px-3 py-1.5 rounded-lg transition glass text-gray-400 hover:text-white js-log-type-btn" data-logtype="user">👤 操作日志</button>
    <button class="text-xs px-3 py-1.5 rounded-lg transition glass text-gray-400 hover:text-white js-log-type-btn" data-logtype="all">📋 全部</button>
    <div class="flex-1"></div>
    <button id="btn-clear-logs" class="text-red-400 hover:text-red-300 text-xs">🗑 清空</button>
  </div>

  <div class="glass rounded-2xl overflow-hidden">
    <div class="overflow-x-auto max-h-[500px] overflow-y-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-gray-500 border-b border-white/5 text-xs sticky top-0" style="background:rgba(15,11,30,0.95)">
          <tr><th class="py-3 px-4">时间</th><th class="py-3 px-4">来源</th><th class="py-3 px-4">操作</th><th class="py-3 px-4">详情</th></tr>
        </thead>
        <tbody class="text-gray-300" id="log-body">
          <% logs.rows.forEach(function(l) { %>
          <tr class="border-b border-white/5">
            <td class="py-2 px-4 text-xs text-gray-500"><%= l.created_at %></td>
            <td class="py-2 px-4 text-xs"><%= l.ip === 'system' ? '<span class="text-amber-400">系统</span>' : (l.username || '-') %></td>
            <td class="py-2 px-4 text-xs"><%= l.action %></td>
            <td class="py-2 px-4 text-xs text-gray-500 max-w-xs truncate"><%= l.detail || '' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div class="flex items-center justify-between p-3 border-t border-white/5">
      <span class="text-gray-600 text-xs" id="log-info">共 <%= logs.total %> 条</span>
      <div class="flex gap-1" id="log-pager"></div>
    </div>
  </div>
</div>

<!-- 安全中心 Tab -->
<div class="tab-panel space-y-4" data-tab="abuse">
  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-3">⚙️ 风控配置</h3>
    <p class="text-gray-600 text-xs mb-3">订阅防护参数，保存后立即生效无需重启</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
      <div>
        <label class="text-gray-500 text-xs block mb-1">防护模式</label>
        <select id="guard-mode" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
          <option value="off">关闭</option><option value="observe">观察（仅记录）</option><option value="enforce">强制（拦截）</option>
        </select>
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">Token 限速窗口(秒)</label>
        <input type="number" id="guard-token-window" min="1" max="3600" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">窗口内最大请求</label>
        <input type="number" id="guard-token-max-req" min="1" max="1000" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">封禁时长(秒)</label>
        <input type="number" id="guard-token-ban" min="5" max="86400" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">行为检测窗口(秒)</label>
        <input type="number" id="guard-behavior-window" min="5" max="3600" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">最大 IP 数</label>
        <input type="number" id="guard-max-ips" min="1" max="100" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">最大 UA 数</label>
        <input type="number" id="guard-max-uas" min="1" max="100" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">24h UA 超限自动重置订阅和UUID</label>
        <input type="number" id="guard-auto-reset-ua-24h-limit" min="0" max="20" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm" placeholder="0=关闭，2=第3个UA触发">
      </div>
    </div>
    <div class="mb-3">
      <label class="text-gray-500 text-xs block mb-1">UA 白名单（逗号分隔，留空用默认）</label>
      <input type="text" id="guard-ua-allowlist" placeholder="clash,v2rayn,shadowrocket..." class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
    </div>
    <p class="text-gray-600 text-xs mb-3">示例：设为 <code>2</code> 时，同一用户 24 小时内出现第 3 个不同 UA，会自动重置订阅链接和该用户全部节点 UUID；旧订阅和旧节点配置都会失效，并清空该用户最近 24 小时的订阅访问记录重新计数。</p>
    <button id="btn-save-guard" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition">保存</button>
  </div>

  <div class="glass rounded-2xl p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-white text-sm font-medium">🛡️ 安全中心</h3>
      <div class="flex items-center gap-2 flex-wrap">
        <button id="security-view-substats" class="bg-rose-600 hover:bg-rose-500 text-white text-xs px-3 py-1.5 rounded-lg transition">订阅访问统计</button>
        <button id="security-view-multinode" class="glass text-gray-300 hover:text-white text-xs px-3 py-1.5 rounded-lg transition">并发多节点观察</button>
      </div>
    </div>
    <div id="security-substats-panel">
      <div class="flex items-center gap-2 flex-wrap mb-3">
        <select id="substats-hours" class="bg-black/30 text-gray-300 text-xs px-2 py-1 rounded-lg border border-white/10">
          <option value="1">1小时</option><option value="24" selected>24小时</option><option value="72">3天</option><option value="168">7天</option>
        </select>
        <select id="substats-sort" class="bg-black/30 text-gray-300 text-xs px-2 py-1 rounded-lg border border-white/10">
          <option value="request">总请求</option><option value="success">成功数</option><option value="deny">拒绝数</option><option value="ok_rate">成功率</option><option value="ip">IP数量</option><option value="ua">UA数量</option><option value="last">最近拉取</option>
        </select>
        <label class="flex items-center gap-1 text-gray-400 text-xs"><input type="checkbox" id="substats-high" class="accent-rose-500"> 仅高风险用户</label>
        <button id="btn-load-substats" class="bg-rose-600 hover:bg-rose-500 text-white text-xs px-3 py-1.5 rounded-lg transition">查询</button>
      </div>
      <div id="substats-overview" class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3"></div>
      <div id="substats-result">
        <p class="text-gray-600 text-sm text-center py-4">点击「查询」查看统计</p>
      </div>
      <div id="substats-pager" class="flex justify-center gap-2 mt-3"></div>
    </div>
    <div id="security-multinode-panel" class="hidden">
      <div class="flex items-center gap-2 flex-wrap mb-3">
        <select id="multinode-hours" class="bg-black/30 text-gray-300 text-xs px-2 py-1 rounded-lg border border-white/10">
          <option value="1">1小时</option><option value="24" selected>24小时</option><option value="72">3天</option><option value="168">7天</option>
        </select>
        <button id="btn-load-multinode" class="bg-rose-600 hover:bg-rose-500 text-white text-xs px-3 py-1.5 rounded-lg transition">查询</button>
      </div>
      <div id="multinode-overview" class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3"></div>
      <div id="multinode-result">
        <p class="text-gray-600 text-sm text-center py-4">点击「查询」查看并发观察</p>
      </div>
      <div id="multinode-pager" class="flex justify-center gap-2 mt-3"></div>
    </div>
  </div>
  <div class="glass rounded-2xl p-5 hidden" id="substats-detail-panel">
    <h3 class="text-white text-sm font-medium mb-3" id="substats-detail-title">用户详情</h3>
    <div id="substats-detail"></div>
  </div>
</div>

<!-- 通知 Tab（仅 TG 配置和事件开关） -->
<div class="tab-panel space-y-4" data-tab="notify">
  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-4">🔔 Telegram 通知配置</h3>
    <div class="grid grid-cols-2 gap-3 mb-4">
      <div>
        <label class="text-gray-500 text-xs block mb-1">Bot Token</label>
        <input type="password" id="tg-token" value="" placeholder="<%= tgBotToken ? '已配置（留空保留原值）' : '123456:ABC-DEF...' %>" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
      <div>
        <label class="text-gray-500 text-xs block mb-1">Chat ID</label>
        <input type="text" id="tg-chat-id" value="<%= (typeof tgChatId !== 'undefined' ? tgChatId : '') %>" placeholder="-100123456789" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
      </div>
    </div>
    <div class="flex gap-2 mb-6">
      <button id="btn-save-tg" class="bg-rose-600 hover:bg-rose-500 text-white text-xs px-4 py-2 rounded-xl transition">保存</button>
      <button id="btn-test-tg" class="glass text-gray-300 hover:text-white text-xs px-4 py-2 rounded-xl transition">发送测试</button>
    </div>
    <h3 class="text-white text-sm font-medium mb-3">📧 SMTP 邮件配置</h3>
    <div class="space-y-3 mb-6">
      <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
        <span class="text-white text-sm">启用 SMTP 发信</span>
        <div class="relative flex-shrink-0">
          <input type="checkbox" id="smtp-enabled" class="sr-only peer" <%= smtpEnabled ? 'checked' : '' %>>
          <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
          <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
        </div>
      </label>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-gray-500 text-xs block mb-1">SMTP Host</label>
          <input type="text" id="smtp-host" value="<%= smtpHost %>" placeholder="smtp.example.com" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        </div>
        <div>
          <label class="text-gray-500 text-xs block mb-1">SMTP Port</label>
          <input type="number" id="smtp-port" value="<%= smtpPort %>" min="1" max="65535" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        </div>
        <div>
          <label class="text-gray-500 text-xs block mb-1">用户名</label>
          <input type="text" id="smtp-user" value="<%= smtpUser %>" placeholder="no-reply@example.com" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        </div>
        <div>
          <label class="text-gray-500 text-xs block mb-1">密码（留空不修改）</label>
          <input type="password" id="smtp-pass" value="" placeholder="••••••••" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        </div>
        <div>
          <label class="text-gray-500 text-xs block mb-1">发件人名称</label>
          <input type="text" id="smtp-from-name" value="<%= smtpFromName %>" placeholder="大姨子的诱惑" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        </div>
        <div>
          <label class="text-gray-500 text-xs block mb-1">发件邮箱</label>
          <input type="email" id="smtp-from-email" value="<%= smtpFromEmail %>" placeholder="no-reply@example.com" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        </div>
      </div>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-gray-400 text-xs">
          <input type="checkbox" id="smtp-secure" class="accent-rose-500" <%= smtpSecure ? 'checked' : '' %>>
          使用 SSL/TLS (通常 465 端口)
        </label>
      </div>
      <div class="flex flex-wrap gap-2">
        <button id="btn-save-smtp" class="bg-rose-600 hover:bg-rose-500 text-white text-xs px-4 py-2 rounded-xl transition">保存 SMTP</button>
        <input type="email" id="smtp-test-to" placeholder="测试收件邮箱" class="flex-1 min-w-[200px] bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        <button id="btn-test-smtp" class="glass text-gray-300 hover:text-white text-xs px-4 py-2 rounded-xl transition">发送测试邮件</button>
      </div>
    </div>
    <h3 class="text-white text-sm font-medium mb-3">通知事件</h3>
    <div class="space-y-2">
      <% var events = [
        { key: 'tg_on_node_down', label: '🔴 节点离线/恢复', desc: '节点上下线状态变化时通知' },
        { key: 'tg_on_node_blocked', label: '🧱 节点被墙', desc: '检测到节点疑似被墙时通知' },
        { key: 'tg_on_rotate', label: '🔄 自动轮换', desc: '每日轮换完成后通知' },
        { key: 'tg_on_abuse', label: '⚠️ 订阅异常', desc: '检测到多IP拉取时通知' },
        { key: 'tg_on_traffic', label: '📊 流量超标', desc: '用户流量超过设定阈值时通知' },
        { key: 'tg_on_register', label: '👤 新用户注册', desc: '有新用户注册时通知' },
        { key: 'tg_on_deploy', label: '🚀 节点部署', desc: '节点部署成功或失败时通知' }
      ]; events.forEach(function(ev) { %>
        <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
          <div>
            <span class="text-white text-sm"><%= ev.label %></span>
            <span class="text-gray-600 text-xs ml-2"><%= ev.desc %></span>
          </div>
          <div class="relative flex-shrink-0">
            <input type="checkbox" class="tg-event sr-only peer" data-key="<%= ev.key %>" <%= (typeof tgEvents !== 'undefined' && tgEvents[ev.key]) ? 'checked' : '' %>>
            <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
            <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
          </div>
        </label>
      <% }); %>
    </div>
  </div>
</div>

<!-- 设置 Tab -->
<div class="tab-panel space-y-4" data-tab="settings">
  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-3">📢 公告管理</h3>
    <div class="flex gap-2">
      <input type="text" id="announcement-text" value="<%= announcement %>" placeholder="输入公告内容（留空则不显示）" class="flex-1 bg-black/30 text-white px-4 py-2 rounded-xl border border-white/10 text-sm">
      <button id="btn-save-announcement" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition">保存</button>
    </div>
  </div>

  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-3">👥 注册管理</h3>
    <p class="text-gray-600 text-xs mb-3">当前已注册 <span class="text-rose-400"><%= userCount %></span> 人，已绑定 TG <span class="text-rose-400"><%= tgBoundUserCount %></span> 人</p>
    <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
      <div>
        <span class="text-white text-sm">开放注册</span>
        <p class="text-gray-600 text-[11px] mt-0.5">关闭后新用户无法注册</p>
      </div>
      <div class="relative">
        <input type="checkbox" id="registration-open-toggle" class="sr-only peer" <%= registrationOpen ? 'checked' : '' %>>
        <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
        <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
      </div>
    </label>
    <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition mt-2">
      <div>
        <span class="text-white text-sm">邀请码注册</span>
        <p class="text-gray-600 text-[11px] mt-0.5">开启后非首位用户必须填写邀请码；关闭后可直接注册</p>
      </div>
      <div class="relative">
        <input type="checkbox" id="invite-registration-open-toggle" class="sr-only peer" <%= inviteRegistrationOpen ? 'checked' : '' %>>
        <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
        <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
      </div>
    </label>
    <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition mt-2">
      <div>
        <span class="text-white text-sm">NodeLoc 注册</span>
        <p class="text-gray-600 text-[11px] mt-0.5">关闭后 NodeLoc 新用户无法注册（老用户登录不受影响）</p>
      </div>
      <div class="relative">
        <input type="checkbox" id="nodeloc-registration-open-toggle" class="sr-only peer" <%= nodelocRegistrationOpen ? 'checked' : '' %>>
        <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
        <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
      </div>
    </label>
    <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition mt-2">
      <div>
        <span class="text-white text-sm">NodeLoc 登录 (联合登录)</span>
        <p class="text-gray-600 text-[11px] mt-0.5">关闭后登录页将隐藏 NodeLoc 登录入口</p>
      </div>
      <div class="relative">
        <input type="checkbox" id="nodeloc-login-open-toggle" class="sr-only peer" <%= nodelocLoginOpen ? 'checked' : '' %>>
        <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
        <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
      </div>
    </label>
    <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition mt-2">
      <div>
        <span class="text-white text-sm">未绑定 TG 自动删除</span>
        <p class="text-gray-600 text-[11px] mt-0.5">开启后，注册超过 <%= autoDeleteUnboundDays %> 天仍未绑定 Telegram 的非管理员账号将于每天凌晨自动删除（含老用户，不可恢复）</p>
      </div>
      <div class="relative">
        <input type="checkbox" id="auto-delete-unbound-toggle" class="sr-only peer" <%= autoDeleteUnboundEnabled ? 'checked' : '' %>>
        <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
        <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
      </div>
    </label>
    <div class="mt-3 p-3 rounded-xl bg-black/20">
      <label class="text-gray-500 text-xs block mb-1">允许注册的邮箱后缀</label>
      <div class="flex gap-2">
        <input type="text" id="allowed-email-domains" value="<%= allowedEmailDomains %>" placeholder="留空不限制，如 gmail.com,qq.com" class="flex-1 bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
        <button id="btn-save-email-domains" class="bg-rose-600 hover:bg-rose-500 text-white px-3 py-2 rounded-xl text-sm transition">保存</button>
      </div>
      <p class="text-gray-600 text-[11px] mt-1">多个后缀用逗号分隔，留空表示不限制</p>
    </div>
  </div>

  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-3">📡 订阅协议展示</h3>
    <p class="text-gray-600 text-xs mb-3">控制用户面板中展示哪些协议的订阅地址</p>
    <div class="space-y-2">
      <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
        <div>
          <span class="text-white text-sm">🌐 VLESS（IPv4）</span>
        </div>
        <div class="relative">
          <input type="checkbox" id="sub-visible-vless" class="sr-only peer" <%= subVisibleVless ? 'checked' : '' %>>
          <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
          <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
        </div>
      </label>
      <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
        <div>
          <span class="text-white text-sm">🌐 Shadowsocks（IPv6）</span>
        </div>
        <div class="relative">
          <input type="checkbox" id="sub-visible-ss" class="sr-only peer" <%= subVisibleSs ? 'checked' : '' %>>
          <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
          <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
        </div>
      </label>
      <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
        <div>
          <span class="text-white text-sm">⚡ Hysteria 2</span>
        </div>
        <div class="relative">
          <input type="checkbox" id="sub-visible-hy2" class="sr-only peer" <%= subVisibleHy2 ? 'checked' : '' %>>
          <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
          <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
        </div>
      </label>
    </div>
    <button id="btn-save-sub-visibility" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition mt-3">保存</button>
  </div>

  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-3">🔄 用户组重置周期</h3>
    <p class="text-gray-600 text-xs mb-3">设置每个用户组的 UUID 和订阅 Token 重置间隔（天），0 = 不重置</p>
    <div id="group-reset-config" style="display:grid;grid-template-columns:80px 1fr 1fr;gap:8px 12px;align-items:center">
      <span class="text-xs text-gray-500">用户组</span><span class="text-xs text-gray-500">UUID 重置(天)</span><span class="text-xs text-gray-500">订阅重置(天)</span>
    </div>
    <button id="btn-save-group-reset" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition mt-3">保存</button>
    <div class="mt-4 pt-3 border-t border-white/10">
      <p class="text-gray-500 text-xs mb-2">端口轮换周期（天），0 = 不轮换，所有节点共享同一周期</p>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-300">🔌 端口轮换</span>
        <input type="number" id="port-rotate-days" min="0" max="365" value="1" class="w-20 bg-black/30 text-white px-3 py-1.5 rounded-xl border border-white/10 text-sm">
        <span class="text-xs text-gray-500">天</span>
      </div>
    </div>
  </div>

  <div class="glass rounded-2xl p-5">
    <h3 class="text-white text-sm font-medium mb-3">📦 默认流量限额</h3>
    <p class="text-gray-600 text-xs mb-3">新用户注册时的默认流量上限（GB），-1 = 无限</p>
    <div class="flex flex-wrap gap-2">
      <input id="default-traffic-limit" value="<%= defaultTrafficLimit < 0 ? -1 : (defaultTrafficLimit / 1073741824).toFixed(2) %>" min="-1" step="any" placeholder="-1 = 无限" class="flex-1 min-w-[120px] bg-black/30 text-white px-4 py-2 rounded-xl border border-white/10 text-sm [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
      <span class="text-gray-500 text-sm self-center">GB</span>
      <button id="btn-save-default-traffic-limit" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition">保存</button>
      <button id="btn-apply-default-traffic-limit" class="glass text-gray-200 px-4 py-2 rounded-xl text-sm hover:bg-white/10 transition whitespace-nowrap">应用到全部用户</button>
    </div>
    <div class="mt-4 pt-4 border-t border-white/10">
      <h4 class="text-white text-sm font-medium mb-2">默认用户分组</h4>
      <p class="text-gray-600 text-xs mb-3">新用户注册后的初始用户组</p>
      <div class="flex flex-wrap gap-2">
        <select id="default-user-group" class="flex-1 min-w-[160px] bg-black/30 text-white px-4 py-2 rounded-xl border border-white/10 text-sm">
          <% USER_GROUPS.forEach(function(g, i) { %>
          <option value="<%= i %>" <%= (defaultUserGroup || 0) === i ? 'selected' : '' %>><%= g.badge ? g.badge + ' ' : '' %><%= g.name %></option>
          <% }); %>
        </select>
        <button id="btn-save-default-user-group" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition">保存</button>
      </div>
    </div>
  </div>

  <!-- 自动化运维配置 -->
  <div class="glass rounded-2xl p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-white text-sm font-medium">🤖 自动化运维</h3>
      <button id="btn-save-automation" class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-xl text-sm transition">保存配置</button>
    </div>

    <!-- 流量超标策略 -->
    <div class="mb-4">
      <h4 class="text-gray-400 text-xs font-medium mb-2 uppercase tracking-wider">流量超标策略</h4>
      <div class="space-y-3">
        <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
          <div>
            <span class="text-white text-sm">流量超标自动冻结</span>
            <p class="text-gray-600 text-[11px] mt-0.5">关闭后仅发送通知，不会自动冻结用户；用户登录面板后自动解冻</p>
          </div>
          <div class="relative">
            <input type="checkbox" id="auto-freeze-traffic-enabled" class="sr-only peer">
            <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
            <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
          </div>
        </label>
        <div id="traffic-freeze-options">
          <div>
            <label class="text-gray-500 text-xs block mb-1">处置方式</label>
            <select id="traffic-exceed-action" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
              <option value="notify">仅通知（超硬上限才冻结）</option>
              <option value="freeze">超阈值自动冻结</option>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-3">
            <div>
              <label class="text-gray-500 text-xs block mb-1">告警阈值 (GB/天)</label>
              <input type="number" id="traffic-exceed-threshold-gb" min="1" max="10000" value="20" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
            </div>
            <div>
              <label class="text-gray-500 text-xs block mb-1">硬上限 (GB/天)</label>
              <input type="number" id="traffic-exceed-hard-limit-gb" min="1" max="10000" value="50" class="w-full bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
            </div>
          </div>
          <p class="text-gray-600 text-[11px] mt-2">「仅通知」模式：超告警阈值发通知，超硬上限才冻结；「自动冻结」模式：超阈值即冻结</p>
        </div>
      </div>
    </div>

    <!-- 用户流量预警（发到用户 TG 私聊） -->
    <div class="mb-4">
      <h4 class="text-gray-400 text-xs font-medium mb-2 uppercase tracking-wider">用户流量预警</h4>
      <div class="space-y-3">
        <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
          <div>
            <span class="text-white text-sm">单日流量预警</span>
            <p class="text-gray-600 text-[11px] mt-0.5">已绑定 TG 的用户当日流量超过阈值时，由机器人私聊提醒用户检查订阅是否泄露。同一用户每日仅提醒一次。</p>
          </div>
          <div class="relative">
            <input type="checkbox" id="traffic-alert-enabled" class="sr-only peer">
            <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
            <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
          </div>
        </label>
        <div id="traffic-alert-options">
          <label class="text-gray-500 text-xs block mb-1">阈值 (GB/天)</label>
          <div class="flex items-center gap-2">
            <input type="number" id="traffic-alert-threshold-gb" min="1" max="10000" value="100" class="w-32 bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
            <span class="text-gray-500 text-sm">GB</span>
          </div>
        </div>
      </div>
    </div>

    <!-- TG 未签到自动冻结 -->
    <div class="mb-4">
      <h4 class="text-gray-400 text-xs font-medium mb-2 uppercase tracking-wider">TG 未签到策略</h4>
      <div class="space-y-3">
        <label class="flex items-center justify-between p-3 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition">
          <div>
            <span class="text-white text-sm">未签到自动冻结</span>
            <p class="text-gray-600 text-[11px] mt-0.5">已绑定 TG 的用户超过指定天数未在 TG 签到将被自动冻结；用户在 TG 签到一次后自动解冻。未绑定 TG 的用户不受影响。</p>
          </div>
          <div class="relative">
            <input type="checkbox" id="auto-freeze-no-checkin-enabled" class="sr-only peer">
            <div class="w-9 h-5 bg-gray-600 rounded-full peer-checked:bg-rose-500 transition-colors"></div>
            <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
          </div>
        </label>
        <div id="no-checkin-freeze-options">
          <label class="text-gray-500 text-xs block mb-1">未签到天数阈值</label>
          <div class="flex items-center gap-2">
            <input type="number" id="auto-freeze-no-checkin-days" min="1" max="365" value="30" class="w-32 bg-black/30 text-white px-3 py-2 rounded-xl border border-white/10 text-sm">
            <span class="text-gray-500 text-sm">天</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Agent 批量更新 -->
    <div>
      <h4 class="text-gray-400 text-xs font-medium mb-2 uppercase tracking-wider">Agent 管理</h4>
      <div class="p-3 rounded-xl bg-black/20">
        <div class="flex items-center justify-between">
          <div>
            <span class="text-white text-sm">批量更新所有在线 Agent</span>
            <p class="text-gray-600 text-[11px] mt-0.5">向所有在线 Agent 下发 self_update 命令，自动下载最新代码并重启</p>
          </div>
          <button id="btn-agent-update-all" class="bg-amber-600 hover:bg-amber-500 text-white px-4 py-2 rounded-xl text-sm transition whitespace-nowrap">🚀 一键更新</button>
        </div>
        <div id="agent-update-result" class="hidden mt-2 text-xs text-gray-400"></div>
      </div>
    </div>
  </div>
</div>
