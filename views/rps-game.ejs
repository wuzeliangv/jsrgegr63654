<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>猜拳赢流量</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
:root{
  --bg:#07111f;
  --bg2:#10263f;
  --panel:rgba(9,18,34,.76);
  --line:rgba(255,255,255,.08);
  --text:#f8fafc;
  --muted:#8ea3bd;
  --accent:#f97316;
  --accent2:#38bdf8;
  --win:#34d399;
  --draw:#fbbf24;
  --lose:#fb7185;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{
  min-height:100vh;
  font-family:"SF Pro Display","Noto Sans SC","PingFang SC",system-ui,sans-serif;
  color:var(--text);
  background:
    radial-gradient(circle at top, rgba(56,189,248,.22), transparent 32%),
    radial-gradient(circle at 80% 20%, rgba(249,115,22,.22), transparent 26%),
    linear-gradient(160deg, var(--bg), var(--bg2) 58%, #0b1730);
  overflow-x:hidden;
  overflow-y:auto;
}
body::before{
  content:"";
  position:fixed;
  inset:0;
  background:
    linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size:32px 32px;
  opacity:.18;
  pointer-events:none;
}
.shell{
  min-height:100vh;
  display:flex;
  align-items:flex-start;
  justify-content:center;
  padding:18px 14px 28px;
}
.arena{
  width:min(100%, 430px);
  margin-bottom:18px;
  border:1px solid var(--line);
  background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
  backdrop-filter:blur(16px);
  border-radius:28px;
  box-shadow:0 28px 80px rgba(0,0,0,.38);
  overflow:hidden;
}
.topbar{
  padding:14px 16px 6px;
}
.eyebrow{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-size:11px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#d7e6f8;
  padding:7px 10px;
  border:1px solid rgba(255,255,255,.1);
  border-radius:999px;
  background:rgba(255,255,255,.05);
}
.eyebrow-dot{
  width:7px;
  height:7px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--accent),#fde68a);
  box-shadow:0 0 14px rgba(249,115,22,.7);
}
.title{
  margin-top:10px;
  font-size:28px;
  line-height:1.02;
  font-weight:800;
}
.hero-stats{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
  margin-top:14px;
}
.stat-card{
  padding:10px 8px;
  border-radius:16px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  text-align:center;
}
.stat-k{
  font-size:11px;
  color:var(--muted);
}
.stat-v{
  margin-top:4px;
  font-size:18px;
  font-weight:800;
}
.stage{
  margin:10px 16px 0;
  padding:14px;
  border-radius:20px;
  background:linear-gradient(180deg, rgba(4,10,21,.8), rgba(8,17,32,.55));
  border:1px solid rgba(255,255,255,.06);
}
.stage-head{
  display:flex;
  justify-content:space-between;
  gap:12px;
  align-items:flex-start;
  margin-bottom:12px;
}
.stage-title{
  font-size:13px;
  color:#c9ddf4;
}
.stage-mode{
  font-size:12px;
  color:var(--muted);
}
.signal{
  padding:5px 9px;
  border-radius:999px;
  font-size:11px;
  color:#dbeafe;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.03);
  white-space:nowrap;
}
.vs-area{
  display:grid;
  grid-template-columns:1fr auto 1fr;
  gap:12px;
  align-items:center;
}
.fighter{
  text-align:center;
}
.fighter-label{
  font-size:12px;
  color:var(--muted);
  margin-bottom:10px;
}
.hand{
  height:98px;
  border-radius:22px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:56px;
  border:1px solid rgba(255,255,255,.1);
  transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease, background .25s ease;
}
.hand-user{
  background:linear-gradient(160deg, rgba(249,115,22,.24), rgba(249,115,22,.08));
}
.hand-sys{
  background:linear-gradient(160deg, rgba(56,189,248,.22), rgba(56,189,248,.08));
}
.fighter-note{
  margin-top:8px;
  font-size:12px;
  color:#d5e6f8;
}
.vs-badge{
  width:50px;
  height:50px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:900;
  letter-spacing:.08em;
  background:linear-gradient(135deg, rgba(249,115,22,.28), rgba(56,189,248,.24));
  border:1px solid rgba(255,255,255,.1);
  color:#fff;
  box-shadow:0 10px 30px rgba(0,0,0,.25);
}
.result-box{
  margin:10px 16px 0;
  min-height:84px;
  padding:14px 16px;
  border-radius:18px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.06);
}
.result-tag{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-size:11px;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:#c7d8eb;
}
.result-text{
  margin-top:8px;
  font-size:22px;
  font-weight:800;
}
.result-sub{
  margin-top:4px;
  min-height:20px;
  color:var(--muted);
  font-size:13px;
}
.choices{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:10px;
  padding:10px 16px 0;
}
.choice-btn{
  position:relative;
  border:none;
  min-height:112px;
  border-radius:20px;
  padding:12px 8px 12px;
  cursor:pointer;
  color:var(--text);
  background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
  border:1px solid rgba(255,255,255,.08);
  box-shadow:0 16px 30px rgba(0,0,0,.16);
  transition:transform .18s ease, border-color .18s ease, box-shadow .18s ease, background .18s ease, opacity .18s ease;
}
.choice-btn:active{transform:scale(.96)}
.choice-btn:hover{
  transform:translateY(-2px);
  border-color:rgba(255,255,255,.2);
  box-shadow:0 22px 34px rgba(0,0,0,.22);
}
.choice-btn.active{
  border-color:rgba(249,115,22,.75);
  background:linear-gradient(180deg, rgba(249,115,22,.22), rgba(255,255,255,.05));
}
.choice-btn.disabled{pointer-events:none;opacity:.46}
.choice-icon{
  font-size:42px;
  line-height:1;
}
.choice-name{
  margin-top:8px;
  font-size:16px;
  font-weight:700;
}
.choice-tip{
  margin-top:4px;
  font-size:11px;
  color:var(--muted);
}
.bottom{
  padding:12px 16px 16px;
}
.meta{
  display:block;
}
.meta-card{
  padding:12px 14px;
  border-radius:20px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.06);
}
.meta-k{
  font-size:11px;
  color:var(--muted);
}
.meta-v{
  margin-top:6px;
  font-size:14px;
  line-height:1.45;
  color:#edf5ff;
}
.score-row{
  display:flex;
  gap:10px;
  margin-top:10px;
}
.score-item{
  flex:1;
  padding:12px 8px;
  border-radius:16px;
  text-align:center;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.06);
}
.score-label{
  font-size:11px;
  color:var(--muted);
}
.score-val{
  margin-top:6px;
  font-size:22px;
  font-weight:800;
}
.score-win{color:var(--win)}
.score-draw{color:var(--draw)}
.score-lose{color:var(--lose)}
.shaking{animation:shake .34s ease-in-out infinite}
.bounce{animation:bounce .42s ease}
.pulse{animation:pulse .9s ease}
.win-glow{box-shadow:0 0 0 1px rgba(52,211,153,.32),0 0 34px rgba(52,211,153,.28)}
.lose-glow{box-shadow:0 0 0 1px rgba(251,113,133,.28),0 0 34px rgba(251,113,133,.24)}
@keyframes shake{
  0%,100%{transform:translateY(0) rotate(0)}
  25%{transform:translateY(-3px) rotate(-8deg)}
  75%{transform:translateY(-3px) rotate(8deg)}
}
@keyframes bounce{
  0%{transform:scale(.92)}
  60%{transform:scale(1.08)}
  100%{transform:scale(1)}
}
@keyframes pulse{
  0%{transform:scale(1)}
  50%{transform:scale(1.03)}
  100%{transform:scale(1)}
}
@media (max-width:380px){
  .title{font-size:26px}
  .hand{height:88px;font-size:48px}
  .choice-btn{min-height:102px}
  .choice-icon{font-size:38px}
}
@media (max-height:760px){
  .shell{padding-top:12px}
  .topbar{padding-bottom:4px}
  .hero-stats{margin-top:10px}
  .stage{margin-top:10px}
}
</style>
</head>
<body>
<div class="shell">
  <div class="arena">
    <div class="topbar">
      <div class="eyebrow"><span class="eyebrow-dot"></span>Traffic Duel</div>
      <div class="title">猜拳赢流量</div>
      <div class="hero-stats">
        <div class="stat-card">
          <div class="stat-k">胜利奖励</div>
          <div class="stat-v">+1GB</div>
        </div>
        <div class="stat-card">
          <div class="stat-k">平局结果</div>
          <div class="stat-v">0GB</div>
        </div>
        <div class="stat-card">
          <div class="stat-k">失败代价</div>
          <div class="stat-v">-0.5GB</div>
        </div>
      </div>
    </div>

    <div class="stage">
      <div class="stage-head">
        <div>
          <div class="stage-title">本回合对战</div>
          <div class="stage-mode" id="round-mode">选择你的出拳，系统会立即应战</div>
        </div>
        <div class="signal" id="round-signal">等待出拳</div>
      </div>
      <div class="vs-area">
        <div class="fighter">
          <div class="fighter-label">你</div>
          <div class="hand hand-user" id="hand-user">❓</div>
          <div class="fighter-note" id="fighter-user-note">还没决定</div>
        </div>
        <div class="vs-badge">VS</div>
        <div class="fighter">
          <div class="fighter-label">系统</div>
          <div class="hand hand-sys" id="hand-sys">❓</div>
          <div class="fighter-note" id="fighter-sys-note">等待应战</div>
        </div>
      </div>
    </div>

    <div class="result-box" id="result-box">
      <div class="result-tag">Round Result</div>
      <div class="result-text" id="result-text">准备好就开打</div>
      <div class="result-sub" id="result-sub">选一张牌，系统会用动画和结果把这一回合讲清楚。</div>
    </div>

    <div class="choices" id="choices">
      <button class="choice-btn" data-c="0" type="button">
        <div class="choice-icon">✊</div>
        <div class="choice-name">石头</div>
        <div class="choice-tip">稳，正面压制剪刀</div>
      </button>
      <button class="choice-btn" data-c="1" type="button">
        <div class="choice-icon">✌️</div>
        <div class="choice-name">剪刀</div>
        <div class="choice-tip">快，专门切开布</div>
      </button>
      <button class="choice-btn" data-c="2" type="button">
        <div class="choice-icon">✋</div>
        <div class="choice-name">布</div>
        <div class="choice-tip">柔，反手包住石头</div>
      </button>
    </div>

    <div class="bottom">
      <div class="meta">
        <div class="meta-card">
          <div class="meta-k">本局状态</div>
          <div class="meta-v" id="remaining">正在读取剩余流量与次数...</div>
        </div>
      </div>
      <div class="score-row">
        <div class="score-item">
          <div class="score-label">胜</div>
          <div class="score-val score-win" id="s-win">0</div>
        </div>
        <div class="score-item">
          <div class="score-label">平</div>
          <div class="score-val score-draw" id="s-draw">0</div>
        </div>
        <div class="score-item">
          <div class="score-label">负</div>
          <div class="score-val score-lose" id="s-lose">0</div>
        </div>
      </div>
      <div class="meta-card" style="margin-top:10px">
        <div class="meta-k">净收益</div>
        <div class="meta-v" id="net-gain">0 GB</div>
      </div>
    </div>
  </div>
</div>
<script src="/js/rps.js"></script>
</body>
</html>
