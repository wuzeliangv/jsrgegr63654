<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>找回密码 - 大姨子的诱惑</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" href="/favicon.ico">
  <link rel="stylesheet" href="/css/tailwind.min.css">
  <style nonce="<%= nonce %>">
    *{font-family:'Noto Sans SC',system-ui,-apple-system,sans-serif;box-sizing:border-box}
    body{background:#08060d;min-height:100vh;position:relative;overflow:hidden}
    body::before{content:'';position:fixed;top:-50%;left:-40%;width:90vw;height:90vw;border-radius:50%;background:radial-gradient(circle,rgba(244,63,94,0.12) 0%,rgba(168,85,247,0.06) 40%,transparent 65%);animation:drift 12s ease-in-out infinite alternate}
    body::after{content:'';position:fixed;bottom:-40%;right:-30%;width:70vw;height:70vw;border-radius:50%;background:radial-gradient(circle,rgba(251,146,60,0.08) 0%,rgba(244,63,94,0.04) 40%,transparent 65%);animation:drift 12s ease-in-out infinite alternate-reverse}
    @keyframes drift{0%{transform:translate(0,0) scale(1)}100%{transform:translate(40px,30px) scale(1.05)}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    @keyframes glow{0%,100%{box-shadow:0 0 20px rgba(244,63,94,0.3),0 0 60px rgba(244,63,94,0.1)}50%{box-shadow:0 0 30px rgba(244,63,94,0.5),0 0 80px rgba(244,63,94,0.15)}}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
    @keyframes twinkle{0%,100%{opacity:0.2}50%{opacity:0.8}}
    .stars{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}
    .star{position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;animation:twinkle var(--d) ease-in-out infinite;opacity:0.2}
    .card{background:rgba(255,255,255,0.03);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.06);box-shadow:0 8px 40px rgba(0,0,0,0.5),inset 0 1px 0 rgba(255,255,255,0.05);animation:fadeUp .6s ease-out;position:relative;z-index:1}
    .logo-wrap{animation:float 4s ease-in-out infinite}
    .logo{background:linear-gradient(135deg,#f43f5e,#e11d48,#be123c);animation:glow 3s ease-in-out infinite;position:relative}
    .logo::after{content:'';position:absolute;inset:-4px;border-radius:18px;background:linear-gradient(135deg,rgba(244,63,94,0.4),transparent,rgba(168,85,247,0.3));z-index:-1;filter:blur(8px)}
    .input-wrap{position:relative}
    .input-wrap svg{position:absolute;left:14px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:rgba(255,255,255,0.25);pointer-events:none;transition:color .2s}
    .input-wrap:focus-within svg{color:rgba(244,63,94,0.7)}
    .inp{width:100%;background:rgba(255,255,255,0.04);color:#fff;padding:12px 16px 12px 42px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);font-size:14px;outline:none;transition:all .3s}
    .inp:focus{border-color:rgba(244,63,94,0.5);background:rgba(255,255,255,0.06);box-shadow:0 0 0 3px rgba(244,63,94,0.08)}
    .inp::placeholder{color:rgba(255,255,255,0.2)}
    .btn-primary{background:linear-gradient(135deg,#f43f5e,#e11d48);box-shadow:0 4px 24px rgba(244,63,94,0.35);transition:all .3s;position:relative;overflow:hidden}
    .btn-primary::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);transition:left .5s}
    .btn-primary:hover::before{left:100%}
    .btn-primary:hover{box-shadow:0 8px 36px rgba(244,63,94,0.5);transform:translateY(-1px)}
    .btn-primary:active{transform:translateY(0)}
    #step2,#step3{display:none}
  </style>
</head>
<body class="flex items-center justify-center px-4">
  <div class="stars" id="stars"></div>
  <main class="card rounded-3xl p-10 max-w-sm w-full text-center" role="main">
    <div class="logo-wrap">
      <div class="logo w-18 h-18 mx-auto mb-6 rounded-2xl flex items-center justify-center text-4xl" style="width:72px;height:72px">🔑</div>
    </div>
    <h1 class="text-2xl font-bold text-white mb-1">找回密码</h1>
    <p class="text-gray-500 text-xs mb-6 tracking-widest">RESET PASSWORD</p>

    <div id="msg" class="hidden rounded-xl p-3 mb-4" role="alert"></div>

    <!-- Step 1: 输入邮箱 -->
    <div id="step1" class="text-left">
      <label class="text-gray-500 text-xs block mb-1.5 ml-1">注册邮箱</label>
      <div class="input-wrap mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
        <input type="email" id="email" class="inp" placeholder="your@email.com">
      </div>
      <button id="btn-send" class="btn-primary w-full text-white font-semibold py-3 rounded-xl text-sm">发送验证码</button>
    </div>

    <!-- Step 2: 输入验证码 -->
    <div id="step2" class="text-left">
      <label class="text-gray-500 text-xs block mb-1.5 ml-1">验证码</label>
      <div class="input-wrap mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        <input type="text" id="code" class="inp" maxlength="6" placeholder="6位验证码" style="letter-spacing:4px;text-align:center;padding-left:42px">
      </div>
      <label class="text-gray-500 text-xs block mb-1.5 ml-1">新密码</label>
      <div class="input-wrap mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
        <input type="password" id="pwd" class="inp" placeholder="至少8位">
      </div>
      <label class="text-gray-500 text-xs block mb-1.5 ml-1">确认密码</label>
      <div class="input-wrap mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
        <input type="password" id="pwd2" class="inp" placeholder="再输一次">
      </div>
      <button id="btn-reset" class="btn-primary w-full text-white font-semibold py-3 rounded-xl text-sm">重置密码</button>
    </div>

    <!-- Step 3: 成功 -->
    <div id="step3">
      <div class="text-5xl mb-4">✅</div>
      <p class="text-green-400 text-sm mb-5">密码已重置，请使用新密码登录</p>
      <a href="/auth/login" class="btn-primary inline-block text-white font-semibold py-3 px-8 rounded-xl text-sm">去登录</a>
    </div>

    <a href="/auth/login" class="block mt-6 text-gray-500 text-xs hover:text-rose-400 transition">← 返回登录</a>
  </main>

  <script nonce="<%= nonce %>">
    !function(){const c=document.getElementById('stars');for(let i=0;i<60;i++){const s=document.createElement('div');s.className='star';s.style.cssText='left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;--d:'+(2+Math.random()*4)+'s;animation-delay:-'+Math.random()*4+'s;width:'+(1+Math.random()*2)+'px;height:'+(1+Math.random()*2)+'px';c.appendChild(s)}}();

    const $ = s => document.getElementById(s);
    const msg = (t, err) => { const m = $('msg'); m.className = 'rounded-xl p-3 mb-4'; m.style.borderColor = err ? 'rgba(239,68,68,0.2)' : 'rgba(52,211,153,0.2)'; m.style.border = '1px solid '+(err ? 'rgba(239,68,68,0.2)' : 'rgba(52,211,153,0.2)'); m.style.background = err ? 'rgba(239,68,68,0.08)' : 'rgba(52,211,153,0.08)'; m.innerHTML = '<p class="text-sm" style="color:'+(err?'#f87171':'#6ee7b7')+'">'+t+'</p>'; };
    let email = '';

    $('btn-send').onclick = async () => {
      email = $('email').value.trim();
      if (!email) return msg('请输入邮箱', true);
      $('btn-send').disabled = true; $('btn-send').textContent = '发送中...';
      try {
        const r = await fetch('/auth/forgot-send-code', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>' }, body: JSON.stringify({ email }) });
        const d = await r.json();
        if (d.ok) { $('step1').style.display = 'none'; $('step2').style.display = 'block'; msg('验证码已发送到邮箱'); }
        else msg(d.error || '发送失败', true);
      } catch(e) { msg('网络错误', true); }
      $('btn-send').disabled = false; $('btn-send').textContent = '发送验证码';
    };

    $('btn-reset').onclick = async () => {
      const code = $('code').value.trim(), pwd = $('pwd').value, pwd2 = $('pwd2').value;
      if (!code || code.length !== 6) return msg('请输入6位验证码', true);
      if (pwd.length < 8) return msg('密码至少8位', true);
      if (pwd !== pwd2) return msg('两次密码不一致', true);
      $('btn-reset').disabled = true; $('btn-reset').textContent = '重置中...';
      try {
        const r = await fetch('/auth/forgot-reset', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>' }, body: JSON.stringify({ email, code, password: pwd }) });
        const d = await r.json();
        if (d.ok) { $('step2').style.display = 'none'; $('step3').style.display = 'block'; $('msg').className = 'hidden'; }
        else msg(d.error || '重置失败', true);
      } catch(e) { msg('网络错误', true); }
      $('btn-reset').disabled = false; $('btn-reset').textContent = '重置密码';
    };
  </script>
</body>
</html>
